{
  "compilerOptions": {
    "target": "ES2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "lib": [
      "ES2023"
    ]
  },
  "include": [
    "engine/src/**/*.ts",
    "engine/test/**/*.ts"
  ]
}